{
  "name": "@openbook-studio/frontend-teacher",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.x",
  "scripts": {
    "clean": "node ../../../bin/frontend/clean.js",
    "watch:tailwind": "tailwindcss -i tailwind.css -o src/tailwind.css --watch",
    "watch:src": "node ../../../bin/frontend/watch.js",
    "watch": "npm run build:tailwind && conc -n tailwind,src -c auto \"npm run watch:tailwind\" \"npm run watch:src\"",
    "build:tailwind": "tailwindcss -i tailwind.css -o src/tailwind.css",
    "build:src": "node ../../../bin/frontend/build.js",
    "build": "npm run build:tailwind && npm run build:src",
    "lint": "eslint \"./**/*.{ts,tsx}\"",
    "lintfix": "eslint --fix \"./**/*.{ts,tsx}\"",
    "prettier": "prettier --ignore-path ../../.gitignore \"**/*.+(ts|tsx)\"",
    "format": "npm run prettier -- --write",
    "check": "npm run lint && tsc"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "daisyui": "^5.5.19",
    "svelte-spa-router": "^5.0.1",
    "tailwindcss": "^4.2.4"
  }
}
